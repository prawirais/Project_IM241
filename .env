# Konfigurasi Container
APP_PORT=8000
FORWARD_DB_PORT=33061

# Konfigurasi Database (Gunakan nama service 'db' sebagai host)
DB_CONNECTION=mysql
DB_HOST=db
DB_PORT=3306
DB_DATABASE=laravel_db
DB_USERNAME=user_laravel
DB_PASSWORD=secret_password

# Redis
REDIS_HOST=redis
REDIS_PORT=6379

# Mail (Gunakan Mailpit)
MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null